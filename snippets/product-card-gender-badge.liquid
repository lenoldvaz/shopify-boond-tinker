{%- comment -%}
  Added by DK on 2026-06-26: gender badge pill for product cards, sourced
  from a custom.gender metafield (single line text, e.g. "Men", "Women",
  "Unisex"). Renders alongside (not instead of) the existing
  product-card-badges pill, in its own position so it can coexist with the
  main badge (e.g. top-left badge + top-right gender pill). Position and
  visibility are controlled by the calling block's settings, not hardcoded,
  so it's switchable per-instance from the theme customizer. Markup/CSS
  structure mirrors product-card-badges.liquid.

  Updated by DK on 2026-06-26: switched from Shopify's standard
  shopify.target-gender metaobject to a plain custom.gender text field,
  matching the simpler approach used in shopify-boond-canada - avoids the
  metaobject dereferencing complexity entirely.
{%- endcomment -%}
{%- assign gender = product.metafields.custom.gender.value | default: product.metafields.custom.gender -%}

{%- if show_gender_badge and gender != blank -%}
  <div
    class="product-badges product-badges--{{ gender_badge_position }}"
    style="
      --badge-border-radius: {{ settings.badge_corner_radius }}px;
      --badge-font-family: var(--font-{{ settings.badge_font_family }}--family);
      --badge-font-weight: var(--font-{{ settings.badge_font_family }}--weight);
      --badge-text-transform: {{ settings.badge_text_transform }};
    "
  >
    <div class="product-badges__badge product-badges__badge--rectangle product-badges__badge--outline">
      {{ gender }}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .product-badges__badge--outline {
    background: var(--color-background);
    color: var(--color-foreground);
    border: 1px solid var(--color-border);
  }
{% endstylesheet %}