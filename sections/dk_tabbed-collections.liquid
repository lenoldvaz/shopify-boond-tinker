{% comment %} Added by DK on 2026-05-07 — Tabbed collections section (Dossier-style) {% endcomment %}
{% comment %} Updated by DK on 2026-05-07 — Tabs moved to section settings (no schema blocks) to allow content_for product-card {% endcomment %}
{% comment %} Updated by DK on 2026-05-08 — Configurable active tab highlight colours + per-tab badges {% endcomment %}

{% liquid
  comment
    Tabs are driven by section settings (tab_1_* … tab_6_*) rather than blocks.
    This is required because content_for 'block' (theme blocks) and schema-defined
    blocks cannot coexist in the same section.
  endcomment
  assign max_tabs = 6
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="dk-tabs-section color-{{ section.settings.color_scheme }} spacing-style"
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    --dk-tab-active-bg: {{ section.settings.tab_active_bg }};
    --dk-tab-active-color: {{ section.settings.tab_active_color }};
    --dk-tab-indicator-color: {{ section.settings.tab_indicator_color }};
  "
>

  {%- if section.settings.heading != blank -%}
    <p class="dk-tabs-section__eyebrow">{{ section.settings.heading }}</p>
  {%- endif -%}

  {%- comment -%} ── TAB BAR ── {%- endcomment -%}
  {%- assign first_tab = true -%}
  {%- assign first_tab_idx = 0 -%}
  <div class="dk-tabs-section__tabs" role="tablist">
    {%- for i in (1..max_tabs) -%}
      {%- assign col_key        = 'tab_' | append: i | append: '_collection' -%}
      {%- assign label_key      = 'tab_' | append: i | append: '_label' -%}
      {%- assign img_key        = 'tab_' | append: i | append: '_image' -%}
      {%- assign badge_key      = 'tab_' | append: i | append: '_badge' -%}
      {%- assign badge_color_key = 'tab_' | append: i | append: '_badge_color' -%}
      {%- assign tab_col        = section.settings[col_key] -%}
      {%- assign tab_label      = section.settings[label_key] -%}
      {%- assign tab_img        = section.settings[img_key] -%}
      {%- assign tab_badge      = section.settings[badge_key] -%}
      {%- assign tab_badge_color = section.settings[badge_color_key] -%}
      {%- if tab_col != blank -%}
        {%- if first_tab -%}{%- assign first_tab_idx = i -%}{%- endif -%}
        <button
          class="dk-tabs-section__tab{% if first_tab %} is-active{% endif %}"
          onclick="dkTabsSwitch('{{ section.id }}', {{ i }})"
          id="dkTab-{{ section.id }}-{{ i }}"
          role="tab"
          aria-selected="{% if first_tab %}true{% else %}false{% endif %}"
          aria-controls="dkPanel-{{ section.id }}-{{ i }}"
        >
          {%- if tab_img != blank -%}
            <span class="dk-tabs-section__tab-img-wrap">
              {{- tab_img | image_url: width: 120 | image_tag: loading: 'lazy', widths: '80, 120', class: 'dk-tabs-section__tab-img' -}}
            </span>
          {%- endif -%}
          <span class="dk-tabs-section__tab-label">{{ tab_label | default: tab_col.title }}</span>
          {%- if tab_badge != blank -%}
            <span
              class="dk-tabs-section__badge"
              style="background: {{ tab_badge_color | default: '#9B2335' }};"
            >{{ tab_badge }}</span>
          {%- endif -%}
        </button>
        {%- assign first_tab = false -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} ── PANELS — content_for renders native product cards ── {%- endcomment -%}
  {%- assign max_products = section.settings.max_products -%}
  {%- for i in (1..max_tabs) -%}
    {%- assign col_key        = 'tab_' | append: i | append: '_collection' -%}
    {%- assign view_all_key   = 'tab_' | append: i | append: '_view_all_url' -%}
    {%- assign view_text_key  = 'tab_' | append: i | append: '_view_all_text' -%}
    {%- assign tab_col        = section.settings[col_key] -%}
    {%- assign tab_view_url   = section.settings[view_all_key] -%}
    {%- assign tab_view_text  = section.settings[view_text_key] -%}
    {%- if tab_col != blank -%}
      <div
        class="dk-tabs-section__panel{% if i == first_tab_idx %} is-active{% endif %}"
        id="dkPanel-{{ section.id }}-{{ i }}"
        role="tabpanel"
        aria-labelledby="dkTab-{{ section.id }}-{{ i }}"
      >
        <div
          class="resource-list resource-list--grid"
          style="
            --resource-list-columns: repeat({{ section.settings.columns }}, 1fr);
            --resource-list-columns-mobile: repeat({{ section.settings.mobile_columns }}, 1fr);
            --resource-list-column-gap-desktop: {{ section.settings.columns_gap }}px;
            --resource-list-row-gap-desktop: {{ section.settings.rows_gap }}px;
          "
        >
          {%- for product in tab_col.products limit: max_products -%}
            <div class="resource-list__item">
              {%- content_for 'block', type: 'product-card', id: 'static-product-card', closest.product: product -%}
            </div>
          {%- endfor -%}
        </div>

        {%- assign footer_url = tab_view_url | default: tab_col.url -%}
        {%- if footer_url != blank -%}
          <div class="dk-tabs-section__footer">
            <a href="{{ footer_url }}" class="dk-tabs-section__view-all">
              {{- tab_view_text | default: section.settings.view_all_text -}}
            </a>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- endfor -%}

</div>

{% stylesheet %}
/* Added by DK on 2026-05-07 — dk_tabbed-collections */
.dk-tabs-section {
  padding: 60px 72px;
}

/* Eyebrow */
.dk-tabs-section__eyebrow {
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  opacity: 0.5;
  margin: 0 0 28px;
}

/* ── TAB BAR ── */
.dk-tabs-section__tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid rgba(0,0,0,0.1);
  margin-bottom: 36px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.dk-tabs-section__tabs::-webkit-scrollbar { display: none; }

.dk-tabs-section__tab {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 16px;
  margin-right: 8px;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  border-radius: 6px 6px 0 0;
  cursor: pointer;
  color: rgba(0,0,0,0.4);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  white-space: nowrap;
  transition: color 0.2s, border-color 0.2s, background 0.2s;
  margin-bottom: -1px;
}
.dk-tabs-section__tab:hover { color: rgba(0,0,0,0.7); }
.dk-tabs-section__tab.is-active {
  color: var(--dk-tab-active-color, #1a1a18);
  background: var(--dk-tab-active-bg, transparent);
  border-bottom-color: var(--dk-tab-indicator-color, #1a1a18);
}

/* Per-tab badge pill */
.dk-tabs-section__badge {
  display: inline-flex;
  align-items: center;
  font-size: 8.5px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #fff;
  padding: 2px 6px;
  border-radius: 20px;
  line-height: 1.4;
  flex-shrink: 0;
}

/* Tab image thumbnail */
.dk-tabs-section__tab-img-wrap {
  width: 52px;
  height: 40px;
  border-radius: 6px;
  overflow: hidden;
  flex-shrink: 0;
  background: #f0ede8;
}
.dk-tabs-section__tab-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── PANELS ── */
.dk-tabs-section__panel { display: none; }
.dk-tabs-section__panel.is-active { display: block; }

/* View all footer */
.dk-tabs-section__footer {
  margin-top: 32px;
  text-align: center;
}
.dk-tabs-section__view-all {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #1a1a18;
  text-decoration: none;
  border-bottom: 1px solid #1a1a18;
  padding-bottom: 2px;
  transition: opacity 0.2s;
}
.dk-tabs-section__view-all:hover { opacity: 0.6; }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .dk-tabs-section { padding: 44px 20px; }
  .dk-tabs-section__tab { padding: 12px 20px 12px 0; margin-right: 20px; font-size: 10px; }
  .dk-tabs-section__tab-img-wrap { width: 40px; height: 32px; }
}
{% endstylesheet %}

<script>
/* Added by DK on 2026-05-07 */
function dkTabsSwitch(sectionId, n) {
  var tabPrefix   = 'dkTab-'   + sectionId + '-';
  var panelPrefix = 'dkPanel-' + sectionId + '-';
  document.querySelectorAll('[id^="' + tabPrefix + '"]').forEach(function(el) {
    var active = el.id === tabPrefix + n;
    el.classList.toggle('is-active', active);
    el.setAttribute('aria-selected', active ? 'true' : 'false');
  });
  document.querySelectorAll('[id^="' + panelPrefix + '"]').forEach(function(el) {
    el.classList.remove('is-active');
  });
  var panel = document.getElementById(panelPrefix + n);
  if (panel) panel.classList.add('is-active');
}
</script>

