{% comment %} Added by DK on 2026-05-07 — Tabbed collections section (Dossier-style) {% endcomment %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="dk-tabs-section color-{{ section.settings.color_scheme }} spacing-style"
  style="{%- render 'spacing-style', settings: section.settings -%}"
>

  {%- if section.settings.heading != blank -%}
    <p class="dk-tabs-section__eyebrow">{{ section.settings.heading }}</p>
  {%- endif -%}

  {%- comment -%} ── TAB BAR ── {%- endcomment -%}
  {%- assign first_tab = true -%}
  <div class="dk-tabs-section__tabs" role="tablist">
    {%- for block in section.blocks -%}
      {%- if block.type == 'tab' -%}
        <button
          class="dk-tabs-section__tab{% if first_tab %} is-active{% endif %}"
          onclick="dkTabsSwitch('{{ section.id }}', {{ forloop.index }})"
          id="dkTab-{{ section.id }}-{{ forloop.index }}"
          role="tab"
          aria-selected="{% if first_tab %}true{% else %}false{% endif %}"
          aria-controls="dkPanel-{{ section.id }}-{{ forloop.index }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.tab_image != blank -%}
            <span class="dk-tabs-section__tab-img-wrap">
              {{- block.settings.tab_image | image_url: width: 120 | image_tag: loading: 'lazy', widths: '80, 120', class: 'dk-tabs-section__tab-img' -}}
            </span>
          {%- endif -%}
          <span class="dk-tabs-section__tab-label">{{ block.settings.label }}</span>
        </button>
        {%- assign first_tab = false -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} ── PANELS — use same content_for pattern as product-list section ── {%- endcomment -%}
  {%- assign first_panel = true -%}
  {%- assign max_products = section.settings.max_products -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'tab' -%}
      <div
        class="dk-tabs-section__panel{% if first_panel %} is-active{% endif %}"
        id="dkPanel-{{ section.id }}-{{ forloop.index }}"
        role="tabpanel"
        aria-labelledby="dkTab-{{ section.id }}-{{ forloop.index }}"
      >
        {%- assign col = block.settings.collection -%}
        {%- if col != blank -%}
          <div
            class="resource-list resource-list--grid dk-tabs-section__grid"
            style="
              --resource-list-columns: repeat({{ section.settings.columns }}, 1fr);
              --resource-list-columns-mobile: repeat({{ section.settings.mobile_columns }}, 1fr);
              --resource-list-column-gap-desktop: {{ section.settings.columns_gap }}px;
              --resource-list-row-gap-desktop: {{ section.settings.rows_gap }}px;
            "
          >
            {%- for product in col.products limit: max_products -%}
              <div class="resource-list__item">
                {%- content_for 'block', type: 'product-card', id: 'static-product-card', closest.product: product -%}
              </div>
            {%- endfor -%}
          </div>
          {%- if block.settings.view_all_url != blank or col.url != blank -%}
            <div class="dk-tabs-section__footer">
              <a
                href="{{ block.settings.view_all_url | default: col.url }}"
                class="dk-tabs-section__view-all"
              >
                {{- block.settings.view_all_text | default: section.settings.view_all_text -}}
              </a>
            </div>
          {%- endif -%}
        {%- else -%}
          <p class="dk-tabs-section__empty">Select a collection for this tab.</p>
        {%- endif -%}
      </div>
      {%- assign first_panel = false -%}
    {%- endif -%}
  {%- endfor -%}

</div>

{% stylesheet %}
/* Added by DK on 2026-05-07 — dk_tabbed-collections */
.dk-tabs-section {
  padding: 60px 72px;
}

/* Eyebrow / section heading */
.dk-tabs-section__eyebrow {
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  opacity: 0.5;
  margin: 0 0 28px;
}

/* ── TAB BAR ── */
.dk-tabs-section__tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid rgba(0,0,0,0.1);
  margin-bottom: 36px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.dk-tabs-section__tabs::-webkit-scrollbar { display: none; }

.dk-tabs-section__tab {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 28px 14px 0;
  margin-right: 36px;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  color: rgba(0,0,0,0.4);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  white-space: nowrap;
  transition: color 0.2s, border-color 0.2s;
  margin-bottom: -1px;
}
.dk-tabs-section__tab:hover { color: rgba(0,0,0,0.7); }
.dk-tabs-section__tab.is-active {
  color: #1a1a18;
  border-bottom-color: #1a1a18;
}

/* Tab image thumbnail */
.dk-tabs-section__tab-img-wrap {
  width: 52px;
  height: 40px;
  border-radius: 6px;
  overflow: hidden;
  flex-shrink: 0;
  background: #f0ede8;
}
.dk-tabs-section__tab-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── PANELS ── */
.dk-tabs-section__panel { display: none; }
.dk-tabs-section__panel.is-active { display: block; }

/* View all footer */
.dk-tabs-section__footer {
  margin-top: 32px;
  text-align: center;
}
.dk-tabs-section__view-all {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #1a1a18;
  text-decoration: none;
  border-bottom: 1px solid #1a1a18;
  padding-bottom: 2px;
  transition: opacity 0.2s;
}
.dk-tabs-section__view-all:hover { opacity: 0.6; }

.dk-tabs-section__empty {
  font-size: 13px;
  opacity: 0.4;
  padding: 40px 0;
}

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .dk-tabs-section { padding: 44px 20px; }
  .dk-tabs-section__tab { padding: 12px 20px 12px 0; margin-right: 20px; font-size: 10px; }
  .dk-tabs-section__tab-img-wrap { width: 40px; height: 32px; }
}
{% endstylesheet %}

<script>
/* Added by DK on 2026-05-07 */
function dkTabsSwitch(sectionId, n) {
  var prefix = 'dkTab-' + sectionId + '-';
  /* Update tab buttons */
  document.querySelectorAll('[id^="' + prefix + '"]').forEach(function(el) {
    var active = el.id === prefix + n;
    el.classList.toggle('is-active', active);
    el.setAttribute('aria-selected', active ? 'true' : 'false');
  });
  /* Update panels */
  var panelPrefix = 'dkPanel-' + sectionId + '-';
  document.querySelectorAll('[id^="' + panelPrefix + '"]').forEach(function(el) {
    el.classList.remove('is-active');
  });
  var panel = document.getElementById('dkPanel-' + sectionId + '-' + n);
  if (panel) panel.classList.add('is-active');
}
</script>

{% schema %}
{
  "name": "DK Tabbed Collections",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Tab label",
          "default": "Bestsellers"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "tab_image",
          "label": "Tab image",
          "info": "Optional thumbnail shown in the tab button"
        },
        {
          "type": "url",
          "id": "view_all_url",
          "label": "\"View all\" link",
          "info": "Leave blank to use the collection URL"
        },
        {
          "type": "text",
          "id": "view_all_text",
          "label": "\"View all\" link text",
          "info": "Leave blank to use the section default"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Eyebrow label",
      "default": "Shop our collections"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Products per tab",
      "min": 4,
      "max": 16,
      "step": 4,
      "default": 8
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_columns",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "Column gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "Row gap",
      "min": 8,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Default \"View all\" text",
      "default": "View all →"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "DK Tabbed Collections",
      "blocks": {
        "tab1": {
          "type": "tab",
          "settings": { "label": "Bestsellers" }
        },
        "tab2": {
          "type": "tab",
          "settings": { "label": "New Releases" }
        },
        "tab3": {
          "type": "tab",
          "settings": { "label": "Staff Picks" }
        }
      },
      "block_order": ["tab1", "tab2", "tab3"]
    }
  ]
}
{% endschema %}
