{% comment %} Added by DK on 2026-05-05 — Full-width pull quote with dark background {% endcomment %}

<div class="dk-pq" style="background: {{ section.settings.background_color }}; {%- render 'spacing-style', settings: section.settings -%}">
  <p class="dk-pq__text" style="color: {{ section.settings.text_color }};">{{ section.settings.quote_text }}</p>
  {%- if section.settings.link_text != blank and section.settings.link != blank -%}
    <a href="{{ section.settings.link }}" class="dk-pq__link" style="color: {{ section.settings.link_color }}; border-color: {{ section.settings.link_color | color_modify: 'alpha', 0.3 }};">
      {{ section.settings.link_text }}
    </a>
  {%- endif -%}
</div>

{% stylesheet %}
/* Added by DK on 2026-05-05 */
.dk-pq {
  padding: 84px 72px;
  text-align: center;
}
.dk-pq__text {
  font-family: var(--font-heading--family, Georgia, serif);
  font-size: clamp(22px, 2.8vw, 38px);
  font-weight: 300;
  font-style: italic;
  line-height: 1.45;
  max-width: 820px;
  margin: 0 auto 28px;
}
.dk-pq__link {
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border-bottom-width: 0.5px;
  border-bottom-style: solid;
  padding-bottom: 2px;
  transition: opacity 0.2s;
  text-decoration: none;
  opacity: 0.6;
}
.dk-pq__link:hover { opacity: 1; }
@media (max-width: 768px) {
  .dk-pq { padding: 56px 24px; }
  .dk-pq__text { font-size: clamp(20px, 5.5vw, 28px); }
}
{% endstylesheet %}

{% schema %}
{
  "name": "DK Pull Quote",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote text",
      "default": "\"Our mission is to revive the ancient art of Indian perfume making — and take Indian fragrances to the world.\""
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Our story →"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1D3A2F"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffffdb"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#ffffff99"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0, "max": 120, "step": 8, "unit": "px", "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0, "max": 120, "step": 8, "unit": "px", "default": 80
    }
  ],
  "presets": [
    {
      "name": "DK Pull Quote"
    }
  ]
}
{% endschema %}
