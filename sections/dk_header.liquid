{% comment %} Added by DK on 2026-05-07 — Custom header matching Boond reference design {% endcomment %}
{% comment %} Updated by DK on 2026-05-07 — Image-thumbnail dropdowns with section group headers {% endcomment %}
{% comment %} Updated by DK on 2026-05-07 — Dossier-style mobile drawer: search bar, tab pills, image rows {% endcomment %}

{% liquid
  assign main_menu  = linklists[section.settings.menu]
  assign logo_color = section.settings.logo_color  | default: '#9B2335'
  assign bg_color   = section.settings.bg_color    | default: '#faf8f4'
  assign text_color = section.settings.text_color  | default: '#555550'
  assign border_color = section.settings.border_color | default: '#e2ddd5'
%}

{%- comment -%} ── MOBILE DRAWER OVERLAY ── {%- endcomment -%}
<div class="dk-hdr__overlay" id="dkHdrOverlay" onclick="dkHdrClose()"></div>

{%- comment -%} ── MOBILE DRAWER — Dossier style: search + tabs + image rows ── {%- endcomment -%}
<div class="dk-hdr__drawer" id="dkHdrDrawer" aria-hidden="true">

  {%- comment -%} Top bar: logo + close {%- endcomment -%}
  <div class="dk-hdr__drawer-top">
    <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}" onclick="dkHdrClose()">
      {%- if section.settings.logo_image != blank -%}
        {{- section.settings.logo_image | image_url: height: 44 | image_tag: loading: 'eager', class: 'dk-hdr__drawer-logo-img' -}}
      {%- else -%}
        <svg width="66" height="44" viewBox="0 0 120 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M 10 68 A 50 50 0 0 1 110 68" fill="none" stroke="{{ logo_color }}" stroke-width="1.8"/>
          <line x1="10" y1="68" x2="110" y2="68" stroke="{{ logo_color }}" stroke-width="1.2"/>
          <text x="21" y="64" font-size="9" fill="{{ logo_color }}" font-family="serif">✦</text>
          <text x="88" y="64" font-size="9" fill="{{ logo_color }}" font-family="serif">✦</text>
          <text x="60" y="62" font-size="23" fill="{{ logo_color }}" font-family="serif" text-anchor="middle">बूँद</text>
        </svg>
      {%- endif -%}
    </a>
    <button class="dk-hdr__drawer-close" onclick="dkHdrClose()" aria-label="Close menu">&#x2715;</button>
  </div>

  {%- comment -%} Search bar {%- endcomment -%}
  <div class="dk-hdr__drawer-search">
    <form action="{{ routes.search_url }}" method="get" role="search">
      <div class="dk-hdr__drawer-search-wrap">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" style="flex-shrink:0;opacity:0.45">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="search"
          name="q"
          placeholder="Search fragrances, attars…"
          class="dk-hdr__drawer-search-input"
          autocomplete="off"
          aria-label="Search"
        >
      </div>
    </form>
  </div>

  {%- comment -%} Tab pills — one per nav item that has sub-items {%- endcomment -%}
  {%- assign drawer_tab_count = 0 -%}
  {%- for link in main_menu.links -%}
    {%- if link.links.size > 0 -%}
      {%- assign drawer_tab_count = drawer_tab_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if drawer_tab_count > 0 -%}
    <div class="dk-hdr__drawer-tabs" role="tablist">
      {%- assign tab_idx = 0 -%}
      {%- for link in main_menu.links -%}
        {%- if link.links.size > 0 -%}
          {%- assign tab_idx = tab_idx | plus: 1 -%}
          <button
            class="dk-hdr__drawer-tab{% if tab_idx == 1 %} is-active{% endif %}"
            onclick="dkHdrTab({{ tab_idx }})"
            id="dkTab{{ tab_idx }}"
            role="tab"
            aria-selected="{% if tab_idx == 1 %}true{% else %}false{% endif %}"
            aria-controls="dkPanel{{ tab_idx }}"
          >{{ link.title }}</button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Content panels — image thumbnail rows from blocks {%- endcomment -%}
    {%- assign panel_idx = 0 -%}
    {%- for link in main_menu.links -%}
      {%- if link.links.size > 0 -%}
        {%- assign panel_idx = panel_idx | plus: 1 -%}
        {%- assign panel_idx_str = panel_idx | append: '' -%}
        <div
          class="dk-hdr__drawer-panel{% if panel_idx == 1 %} is-active{% endif %}"
          id="dkPanel{{ panel_idx }}"
          role="tabpanel"
          aria-labelledby="dkTab{{ panel_idx }}"
        >
          {%- assign prev_label = '' -%}
          {%- assign has_block_items = false -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'dropdown_item' and block.settings.parent == panel_idx_str -%}
              {%- assign has_block_items = true -%}
              {%- if block.settings.group_label != blank and block.settings.group_label != prev_label -%}
                <p class="dk-hdr__drawer-group">{{ block.settings.group_label }}</p>
                {%- assign prev_label = block.settings.group_label -%}
              {%- endif -%}
              <a href="{{ block.settings.url | default: '#' }}" class="dk-hdr__drawer-row" onclick="dkHdrClose()" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  <div class="dk-hdr__drawer-thumb">
                    {{- block.settings.image | image_url: width: 80 | image_tag: loading: 'lazy', widths: '60, 80', class: 'dk-hdr__drawer-thumb-img' -}}
                  </div>
                {%- elsif block.settings.image_placeholder != blank -%}
                  <div class="dk-hdr__drawer-thumb" style="background: {{ block.settings.image_placeholder }};"></div>
                {%- else -%}
                  <div class="dk-hdr__drawer-thumb dk-hdr__drawer-thumb--empty"></div>
                {%- endif -%}
                <span class="dk-hdr__drawer-row-title">{{ block.settings.title }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} Fallback to linklist sub-links if no blocks configured — still show placeholder thumbnails {%- endcomment -%}
          {%- unless has_block_items -%}
            {%- assign fallback_colors = '#e8e0d6,#d6e0d0,#e0d6d6,#d6d6e0,#e0dcd0,#d0dce0' | split: ',' -%}
            {%- for sub in link.links -%}
              {%- assign color_idx = forloop.index0 | modulo: 6 -%}
              <a href="{{ sub.url }}" class="dk-hdr__drawer-row" onclick="dkHdrClose()">
                <div class="dk-hdr__drawer-thumb" style="background: {{ fallback_colors[color_idx] }};"></div>
                <span class="dk-hdr__drawer-row-title">{{ sub.title }}</span>
              </a>
            {%- endfor -%}
          {%- endunless -%}

          {%- if panel_idx == 1 and section.settings.shop_all_text != blank -%}
            <a href="{{ section.settings.shop_all_url | default: routes.all_products_collection_url }}" class="dk-hdr__drawer-shopall" onclick="dkHdrClose()">
              {{- section.settings.shop_all_text -}}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- comment -%} Plain links: nav items without sub-links {%- endcomment -%}
  {%- assign has_plain = false -%}
  {%- for link in main_menu.links -%}
    {%- unless link.links.size > 0 -%}{%- assign has_plain = true -%}{%- endunless -%}
  {%- endfor -%}
  {%- if has_plain -%}
    <div class="dk-hdr__drawer-plain-links">
      {%- for link in main_menu.links -%}
        {%- unless link.links.size > 0 -%}
          <a href="{{ link.url }}" class="dk-hdr__drawer-plain" onclick="dkHdrClose()">{{ link.title }}</a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{%- comment -%} ── HEADER ── {%- endcomment -%}
<header
  class="dk-hdr{% if section.settings.sticky %} dk-hdr--sticky{% endif %}"
  id="dkHdr"
  style="
    --dk-hdr-bg: {{ bg_color }};
    --dk-hdr-text: {{ text_color }};
    --dk-hdr-border: {{ border_color }};
    --dk-hdr-logo: {{ logo_color }};
    --dk-hdr-height: {{ section.settings.header_height }}px;
  "
>
  <div class="dk-hdr__inner">

    {%- comment -%} LEFT: hamburger + desktop nav {%- endcomment -%}
    <div class="dk-hdr__left">
      <button class="dk-hdr__hamburger" onclick="dkHdrOpen()" aria-label="Open menu" aria-controls="dkHdrDrawer">
        <span></span><span></span><span></span>
      </button>

      <nav class="dk-hdr__nav" aria-label="Main navigation">
        {%- assign drop_count = 0 -%}
        {%- for link in main_menu.links -%}

          {%- comment -%} Check if this nav item has dropdown blocks — use string comparison (select values are strings) {%- endcomment -%}
          {%- assign link_index = drop_count | plus: 1 -%}
          {%- assign link_index_str = link_index | append: '' -%}
          {%- assign has_blocks = false -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'dropdown_item' and block.settings.parent == link_index_str -%}
              {%- assign has_blocks = true -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if link.links.size > 0 or has_blocks -%}
            {%- assign drop_count = drop_count | plus: 1 -%}
            {%- assign current_drop_str = drop_count | append: '' -%}
            <div class="dk-hdr__drop-wrapper">
              <a href="{{ link.url }}" class="dk-hdr__nav-link dk-hdr__nav-link--drop">{{ link.title }}</a>
              <div class="dk-hdr__dropdown" role="region">

                {%- comment -%} Render blocks if any are configured for this dropdown {%- endcomment -%}
                {%- assign prev_label = '' -%}
                {%- assign has_block_items = false -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'dropdown_item' and block.settings.parent == current_drop_str -%}
                    {%- assign has_block_items = true -%}
                    {%- if block.settings.group_label != blank and block.settings.group_label != prev_label -%}
                      <p class="dk-hdr__dd-group">{{ block.settings.group_label }}</p>
                      {%- assign prev_label = block.settings.group_label -%}
                    {%- endif -%}
                    <a href="{{ block.settings.url | default: '#' }}" class="dk-hdr__dd-row" {{ block.shopify_attributes }}>
                      {%- if block.settings.image != blank -%}
                        <div class="dk-hdr__dd-thumb">
                          {{- block.settings.image | image_url: width: 80 | image_tag: loading: 'lazy', widths: '60, 80', class: 'dk-hdr__dd-thumb-img' -}}
                        </div>
                      {%- elsif block.settings.image_placeholder != blank -%}
                        <div class="dk-hdr__dd-thumb dk-hdr__dd-thumb--color" style="background: {{ block.settings.image_placeholder }};"></div>
                      {%- else -%}
                        <div class="dk-hdr__dd-thumb dk-hdr__dd-thumb--empty"></div>
                      {%- endif -%}
                      <span class="dk-hdr__dd-row-title">{{ block.settings.title | default: block.settings.url }}</span>
                    </a>
                  {%- endif -%}
                {%- endfor -%}

                {%- comment -%} Fallback to linklist sub-links if no blocks configured {%- endcomment -%}
                {%- unless has_block_items -%}
                  {%- if current_drop_str == '1' and section.settings.dropdown_label_1 != blank -%}
                    <p class="dk-hdr__dd-group">{{ section.settings.dropdown_label_1 }}</p>
                  {%- elsif current_drop_str == '2' and section.settings.dropdown_label_2 != blank -%}
                    <p class="dk-hdr__dd-group">{{ section.settings.dropdown_label_2 }}</p>
                  {%- endif -%}
                  {%- assign fallback_colors = '#e8e0d6,#d6e0d0,#e0d6d6,#d6d6e0,#e0dcd0,#d0dce0' | split: ',' -%}
                  {%- for sub in link.links -%}
                    {%- assign color_idx = forloop.index0 | modulo: 6 -%}
                    <a href="{{ sub.url }}" class="dk-hdr__dd-row">
                      <div class="dk-hdr__dd-thumb" style="background: {{ fallback_colors[color_idx] }};"></div>
                      <span class="dk-hdr__dd-row-title">{{ sub.title }}</span>
                    </a>
                  {%- endfor -%}
                {%- endunless -%}

                {%- comment -%} Shop all link (first dropdown only) {%- endcomment -%}
                {%- if current_drop_str == '1' and section.settings.shop_all_text != blank -%}
                  <a href="{{ section.settings.shop_all_url | default: routes.all_products_collection_url }}" class="dk-hdr__dd-shopall">
                    {{- section.settings.shop_all_text -}}
                  </a>
                {%- endif -%}

              </div>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="dk-hdr__nav-link">{{ link.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    </div>

    {%- comment -%} CENTER: logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="dk-hdr__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo_image != blank -%}
        {{- section.settings.logo_image | image_url: height: 58 | image_tag: loading: 'eager', fetchpriority: 'high', class: 'dk-hdr__logo-img' -}}
      {%- else -%}
        <svg width="88" height="58" viewBox="0 0 120 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M 10 68 A 50 50 0 0 1 110 68" fill="none" stroke="{{ logo_color }}" stroke-width="1.8"/>
          <line x1="10" y1="68" x2="110" y2="68" stroke="{{ logo_color }}" stroke-width="1.2"/>
          <text x="21" y="64" font-size="9" fill="{{ logo_color }}" font-family="serif">✦</text>
          <text x="88" y="64" font-size="9" fill="{{ logo_color }}" font-family="serif">✦</text>
          <text x="60" y="62" font-size="23" fill="{{ logo_color }}" font-family="serif" text-anchor="middle" font-weight="400">बूँद</text>
        </svg>
      {%- endif -%}
    </a>

    {%- comment -%} RIGHT: search + cart {%- endcomment -%}
    <div class="dk-hdr__icons">
      <a href="{{ routes.search_url }}" class="dk-hdr__icon-btn" aria-label="Search">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </a>
      <a href="{{ routes.cart_url }}" class="dk-hdr__icon-btn dk-hdr__cart" aria-label="Cart ({{ cart.item_count }} items)">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="dk-hdr__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>
</header>

{% stylesheet %}
/* Added by DK on 2026-05-07 — dk_header styles */
/* Updated by DK on 2026-05-07 — image thumbnail dropdown rows */

/* ── HEADER ── */
.dk-hdr {
  background: var(--dk-hdr-bg, #faf8f4);
  border-bottom: 0.5px solid var(--dk-hdr-border, #e2ddd5);
  height: var(--dk-hdr-height, 72px);
  color: var(--dk-hdr-text, #555550);
  position: relative;
  z-index: 100;
}
.dk-hdr--sticky { position: sticky; top: 0; }
.dk-hdr__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  padding: 0 56px;
  position: relative;
}
.dk-hdr__left { display: flex; align-items: center; gap: 16px; }

/* ── HAMBURGER ── */
.dk-hdr__hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 4px;
  background: none;
  border: none;
}
.dk-hdr__hamburger span {
  display: block;
  height: 1.5px;
  background: var(--dk-hdr-text, #555550);
  border-radius: 2px;
}
.dk-hdr__hamburger span:nth-child(1) { width: 20px; }
.dk-hdr__hamburger span:nth-child(2) { width: 13px; }
.dk-hdr__hamburger span:nth-child(3) { width: 20px; }

/* ── DESKTOP NAV ── */
.dk-hdr__nav { display: flex; align-items: center; gap: 36px; }
.dk-hdr__nav-link {
  font-size: 12.5px;
  letter-spacing: 0.03em;
  color: var(--dk-hdr-text, #555550);
  text-decoration: none;
  transition: color 0.2s;
  white-space: nowrap;
}
.dk-hdr__nav-link:hover { color: #1a1a18; }
.dk-hdr__nav-link--drop::after { content: ' ▾'; font-size: 9px; }

/* ── DROPDOWN ── */
.dk-hdr__drop-wrapper { position: relative; }
.dk-hdr__dropdown {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  background: #fff;
  border: 0.5px solid var(--dk-hdr-border, #e2ddd5);
  border-radius: 0 0 10px 10px;
  box-shadow: 0 12px 36px rgba(0,0,0,0.10);
  padding: 10px 8px 14px;
  min-width: 240px;
  z-index: 200;
}
.dk-hdr__drop-wrapper:hover .dk-hdr__dropdown,
.dk-hdr__drop-wrapper:focus-within .dk-hdr__dropdown { display: block; }

/* Group header */
.dk-hdr__dd-group {
  font-size: 9px;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  color: #9a9a92;
  padding: 10px 12px 4px;
  margin: 0;
}

/* Image row item */
.dk-hdr__dd-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 6px 8px;
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.15s;
  color: #1a1a18;
}
.dk-hdr__dd-row:hover { background: #f5f2ee; }

.dk-hdr__dd-thumb {
  width: 52px;
  height: 52px;
  border-radius: 8px;
  overflow: hidden;
  flex-shrink: 0;
  background: #f0ede8;
}
.dk-hdr__dd-thumb--empty { background: #ede8e0; }
.dk-hdr__dd-thumb-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.dk-hdr__dd-row-title {
  font-size: 13.5px;
  font-weight: 400;
  line-height: 1.3;
}

/* Shop all link */
.dk-hdr__dd-shopall {
  display: inline-block;
  font-size: 10.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--dk-hdr-logo, #9B2335);
  text-decoration: none;
  border-bottom: 0.5px solid var(--dk-hdr-logo, #9B2335);
  padding-bottom: 1px;
  margin: 8px 12px 2px;
}

/* ── LOGO ── */
.dk-hdr__logo {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  text-decoration: none;
  display: flex;
  align-items: center;
}
.dk-hdr__logo-img { height: 58px; width: auto; display: block; }

/* ── ICONS ── */
.dk-hdr__icons { display: flex; align-items: center; gap: 18px; }
.dk-hdr__icon-btn {
  color: var(--dk-hdr-text, #555550);
  text-decoration: none;
  display: flex;
  align-items: center;
  transition: color 0.2s;
  position: relative;
}
.dk-hdr__icon-btn:hover { color: #1a1a18; }
.dk-hdr__cart-count {
  position: absolute;
  top: -6px;
  right: -7px;
  background: var(--dk-hdr-logo, #9B2335);
  color: #fff;
  font-size: 9px;
  font-weight: 500;
  min-width: 15px;
  height: 15px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── MOBILE DRAWER (Dossier style) ── */
.dk-hdr__overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 198;
}
.dk-hdr__overlay.is-open { display: block; }
.dk-hdr__drawer {
  position: fixed;
  inset: 0;
  z-index: 199;
  background: #fff;
  overflow-y: auto;
  transform: translateX(-100%);
  transition: transform 0.28s ease;
  max-width: 400px;
}
.dk-hdr__drawer.is-open { transform: translateX(0); }

/* Drawer top bar */
.dk-hdr__drawer-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px 14px;
}
.dk-hdr__drawer-logo-img { height: 44px; width: auto; }
.dk-hdr__drawer-close {
  font-size: 20px;
  color: var(--dk-hdr-text, #555550);
  background: none;
  border: none;
  cursor: pointer;
  line-height: 1;
  padding: 6px 8px;
}

/* Search bar */
.dk-hdr__drawer-search { padding: 0 16px 14px; }
.dk-hdr__drawer-search-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #f5f2ee;
  border-radius: 8px;
  padding: 11px 14px;
}
.dk-hdr__drawer-search-input {
  flex: 1;
  border: none;
  background: none;
  font-size: 14px;
  outline: none;
  color: #1a1a18;
  min-width: 0;
}
.dk-hdr__drawer-search-input::placeholder { color: #9a9a92; }

/* Tab pills */
.dk-hdr__drawer-tabs {
  display: flex;
  gap: 8px;
  padding: 0 16px 16px;
}
.dk-hdr__drawer-tab {
  flex: 1;
  padding: 9px 10px;
  border-radius: 20px;
  border: 1px solid #e2ddd5;
  background: none;
  font-size: 11.5px;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #555550;
  cursor: pointer;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.dk-hdr__drawer-tab.is-active {
  background: #1a1a18;
  color: #fff;
  border-color: #1a1a18;
}

/* Content panels */
.dk-hdr__drawer-panel { display: none; padding: 0 12px 24px; }
.dk-hdr__drawer-panel.is-active { display: block; }

.dk-hdr__drawer-group {
  font-size: 9.5px;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  color: #9a9a92;
  padding: 14px 6px 6px;
  margin: 0;
}

/* Image thumbnail rows */
.dk-hdr__drawer-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 7px 6px;
  border-radius: 8px;
  text-decoration: none;
  color: #1a1a18;
  transition: background 0.15s;
}
.dk-hdr__drawer-row:hover { background: #f5f2ee; }
.dk-hdr__drawer-thumb {
  width: 52px;
  height: 52px;
  border-radius: 8px;
  overflow: hidden;
  flex-shrink: 0;
  background: #f0ede8;
}
.dk-hdr__drawer-thumb--empty { background: #ede8e0; }
.dk-hdr__drawer-thumb-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.dk-hdr__drawer-row-title {
  font-size: 14px;
  font-weight: 400;
  line-height: 1.3;
}

/* Shop all link inside panel */
.dk-hdr__drawer-shopall {
  display: inline-block;
  font-size: 10.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--dk-hdr-logo, #9B2335);
  text-decoration: none;
  border-bottom: 0.5px solid var(--dk-hdr-logo, #9B2335);
  margin: 16px 8px 4px;
}

/* Plain links (no sub-items) at the bottom */
.dk-hdr__drawer-plain-links {
  margin-top: 8px;
  border-top: 0.5px solid var(--dk-hdr-border, #e2ddd5);
  padding: 8px 16px 16px;
}
.dk-hdr__drawer-plain {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #1a1a18;
  text-decoration: none;
  padding: 12px 4px;
  border-bottom: 0.5px solid var(--dk-hdr-border, #e2ddd5);
}
.dk-hdr__drawer-plain:last-child { border-bottom: none; }

/* ── MOBILE BREAKPOINT ── */
@media (max-width: 768px) {
  .dk-hdr__inner { padding: 0 20px; }
  .dk-hdr__hamburger { display: flex; }
  .dk-hdr__nav { display: none; }
  .dk-hdr__logo { position: static; transform: none; }
  .dk-hdr__logo svg { width: 72px; height: 48px; }
}
{% endstylesheet %}

<script>
/* Added by DK on 2026-05-07 */
/* Updated by DK on 2026-05-07 — tab switcher replaces accordion for mobile drawer */
function dkHdrOpen() {
  document.getElementById('dkHdrDrawer').classList.add('is-open');
  document.getElementById('dkHdrOverlay').classList.add('is-open');
  document.getElementById('dkHdrDrawer').setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
}
function dkHdrClose() {
  document.getElementById('dkHdrDrawer').classList.remove('is-open');
  document.getElementById('dkHdrOverlay').classList.remove('is-open');
  document.getElementById('dkHdrDrawer').setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
}
function dkHdrTab(n) {
  /* Switch active tab pill */
  document.querySelectorAll('.dk-hdr__drawer-tab').forEach(function(el, i) {
    var active = (i + 1 === n);
    el.classList.toggle('is-active', active);
    el.setAttribute('aria-selected', active ? 'true' : 'false');
  });
  /* Switch visible panel */
  document.querySelectorAll('.dk-hdr__drawer-panel').forEach(function(el) {
    el.classList.remove('is-active');
  });
  var panel = document.getElementById('dkPanel' + n);
  if (panel) panel.classList.add('is-active');
}
</script>

