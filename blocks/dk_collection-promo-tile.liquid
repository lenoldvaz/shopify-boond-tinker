{% comment %}
  DK Collection Promo Tile
  Added by DK on 2026-06-26: ported from shopify-boond-canada. A
  promotional banner that occupies one grid cell at a chosen position
  within the collection product grid (rendered by sections/main-collection.liquid),
  interleaved alongside real products. Set "position" to the 1-based slot
  index where this tile should appear (e.g. 1, 10, 15).
{% endcomment %}

{%- liquid
  assign block_settings = block.settings
-%}

<a
  href="{{ block_settings.link | default: '#' }}"
  class="dk-promo-tile spacing-style {% if block_settings.inherit_color_scheme == false %}color-{{ block_settings.color_scheme }}{% endif %}"
  style="{% render 'spacing-style', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  <div class="dk-promo-tile__media">
    {%- if block_settings.image != blank -%}
      {{
        block_settings.image
        | image_url: width: 600
        | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 25vw, 50vw', widths: '300, 450, 600'
      }}
    {%- endif -%}
    {%- if block_settings.badge_text != blank -%}
      <span class="dk-promo-tile__badge">{{ block_settings.badge_text }}</span>
    {%- endif -%}
  </div>
  <div class="dk-promo-tile__content">
    {%- if block_settings.heading != blank -%}
      <p class="dk-promo-tile__heading">{{ block_settings.heading }}</p>
    {%- endif -%}
    {%- if block_settings.subheading != blank -%}
      <p class="dk-promo-tile__subheading">{{ block_settings.subheading }}</p>
    {%- endif -%}
    {%- if block_settings.button_text != blank -%}
      <span class="dk-promo-tile__button button">{{ block_settings.button_text }}</span>
    {%- endif -%}
  </div>
</a>

{% stylesheet %}
  .dk-promo-tile {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .dk-promo-tile__media {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1.25;
    overflow: hidden;
    border-radius: var(--border-radius, 0px);
  }

  .dk-promo-tile__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dk-promo-tile__badge {
    position: absolute;
    top: var(--padding-sm);
    left: var(--padding-sm);
    background: var(--color-foreground);
    color: var(--color-background);
    font-size: var(--font-size--xs);
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 50px;
    text-transform: uppercase;
  }

  .dk-promo-tile__content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-block: var(--padding-sm);
  }

  .dk-promo-tile__heading {
    font-size: var(--font-paragraph--size);
    font-weight: 600;
    margin: 0;
  }

  .dk-promo-tile__subheading {
    font-size: var(--font-size--sm);
    opacity: 0.75;
    margin: 0;
  }

  .dk-promo-tile__button {
    margin-top: 4px;
    align-self: flex-start;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DK Collection Promo Tile",
  "tag": null,
  "settings": [
    {
      "type": "range",
      "id": "position",
      "label": "Grid position",
      "info": "1-based slot where this tile appears in the product grid (e.g. 1, 10, 15). Repeats on every paginated page.",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 1
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "info": "Optional, e.g. \"NEW\""
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "Inherit color scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "DK Collection Promo Tile",
      "category": "DK Blocks"
    }
  ]
}
{% endschema %}
