{% comment %}
  DK Scent Family Pills
  Added by DK on 2026-06-25: static "handcrafted by artisans" pill plus one
  clickable pill per value in product.metafields.custom.scent_family (a
  list metafield, since a product can belong to multiple scent families).
  Each pill links to the all-products collection pre-filtered to that scent
  family (requires the scent_family metafield to have storefront filtering enabled).
  Unmapped values (e.g. a stray "Rare" data entry) are silently skipped.

  Updated by DK on 2026-06-25: added a "Compact" display_mode for use inside
  product cards on collection/grid pages, where space is tight. Compact mode
  drops the static pill and only shows the first scent family, in a smaller pill.
{% endcomment %}

{% liquid
  assign is_compact = block.settings.display_mode == 'compact'
  assign scent_family_values = product.metafields.custom.scent_family.value
  if is_compact and scent_family_values != blank
    assign scent_family_values = scent_family_values | slice: 0, 1
  endif
%}

<div class="dk-scent-family {% if is_compact %}dk-scent-family--compact{% endif %}" {{ block.shopify_attributes }}>
  {%- if block.settings.show_static_pill and is_compact == false -%}
    <span class="dk-scent-family__pill dk-scent-family__pill--static">
      {{ block.settings.static_pill_text }}
    </span>
  {%- endif -%}

  {%- for scent_family_value in scent_family_values -%}
    {% liquid
      assign scent_family = scent_family_value | strip | downcase
      assign pill_color = blank
      assign pill_icon = blank

      case scent_family
        when 'fresh'
          assign pill_color = block.settings.pill_color_fresh
          assign pill_icon = 'snowflake'
        when 'floral'
          assign pill_color = block.settings.pill_color_floral
          assign pill_icon = 'perfume'
        when 'earthy'
          assign pill_color = block.settings.pill_color_earthy
          assign pill_icon = 'leaf'
        when 'spicy'
          assign pill_color = block.settings.pill_color_spicy
          assign pill_icon = 'pepper'
        when 'grassy'
          assign pill_color = block.settings.pill_color_grassy
          assign pill_icon = 'plant'
        when 'musky'
          assign pill_color = block.settings.pill_color_musky
          assign pill_icon = 'paw_print'
        when 'mild sweet'
          assign pill_color = block.settings.pill_color_mild_sweet
          assign pill_icon = 'price_tag'
        when 'woody'
          assign pill_color = block.settings.pill_color_woody
          assign pill_icon = 'leather'
        when 'balsamic'
          assign pill_color = block.settings.pill_color_balsamic
          assign pill_icon = 'bottle'
        when 'smoky'
          assign pill_color = block.settings.pill_color_smoky
          assign pill_icon = 'fire'
        when 'warm'
          assign pill_color = block.settings.pill_color_warm
          assign pill_icon = 'lightning_bolt'
        when 'green'
          assign pill_color = block.settings.pill_color_green
          assign pill_icon = 'recycle'
      endcase
    %}

    {%- if scent_family != blank and pill_color != blank -%}
      <a
        href="{{ routes.all_products_collection_url }}?filter.v.metafield.custom.scent_family={{ scent_family | url_encode }}"
        class="dk-scent-family__pill dk-scent-family__pill--scent"
        style="--pill-color: {{ pill_color }};"
      >
        <svg class="dk-scent-family__icon" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20">
          {%- render 'icon', icon: pill_icon -%}
        </svg>
        {{ scent_family_value }}
      </a>
    {%- endif -%}
  {%- endfor -%}
</div>

{% stylesheet %}
  .dk-scent-family {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .dk-scent-family__pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.4;
    text-decoration: none;
    white-space: nowrap;
  }

  .dk-scent-family--compact .dk-scent-family__pill {
    padding: 2px 7px;
    font-size: 0.6875rem;
    gap: 4px;
  }

  .dk-scent-family--compact .dk-scent-family__icon {
    width: 11px;
    height: 11px;
  }

  .dk-scent-family__pill--static {
    background: var(--color-border);
    color: var(--color-foreground);
  }

  .dk-scent-family__pill--scent {
    background: color-mix(in srgb, var(--pill-color) 15%, white);
    color: var(--pill-color);
    border: 1px solid color-mix(in srgb, var(--pill-color) 35%, white);
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .dk-scent-family__pill--scent:hover {
    background: color-mix(in srgb, var(--pill-color) 25%, white);
  }

  .dk-scent-family__icon {
    fill: currentcolor;
    flex-shrink: 0;
  }
{% endstylesheet %}

{% schema %}
